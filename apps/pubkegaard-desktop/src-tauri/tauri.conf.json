{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pubkegaard",
  "version": "0.1.0",
  "identifier": "org.bitcoinerrorlog.pubkegaard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:bundle",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pubkegaard",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [],
    "externalBin": ["binaries/boringtun-cli"],
    "resources": ["binaries/boringtun-cli-aarch64-apple-darwin"],
    "targets": ["dmg", "msi", "deb", "rpm", "appimage"],
    "publisher": "BitcoinErrorLog"
  }
}
